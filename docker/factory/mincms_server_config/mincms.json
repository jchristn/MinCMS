{
  "Rest": {
    "Hostname": "*",
    "Port": 8200,
    "Ssl": false
  },
  "S3": {
    "AccessKey": "{s3-access-key}",
    "SecretKey": "{s3-secret-key}",
    "Bucket": "{s3-bucket}",
    "Region": "us-east-2",
    "EndpointUrl": null,
    "UseSsl": true,
    "RequestStyle": "VirtualHosted"
  },
  "AccessKeys": [
    {
      "Name": "Admin",
      "Key": "mincmsadmin"
    }
  ],
  "Logging": {
    "ConsoleLogging": true,
    "MinimumSeverity": 1,
    "EnableColors": false,
    "FileLogging": true,
    "LogDirectory": "./logs/",
    "LogFilename": "mincms.log",
    "IncludeDateInFilename": true,
    "Servers": []
  }
}
